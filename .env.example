# ─── Application ────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database ────────────────────────────────────────────────
# Get this from Supabase Project Settings > Database
# Ensure you use Transactional Mode (port 6543) for connection pooling
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# ─── JWT ─────────────────────────────────────────────────────
# Minimum 16 characters for security
JWT_SECRET=finance_dashboard_super_secret_jwt_key_2475836
JWT_EXPIRES_IN=7d

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ─────────────────────────────────────────────────
# trace, debug, info, warn, error, fatal
LOG_LEVEL=info
