# ─── Application Configuration ────────────────────────────────
# Set to 'production' for live deployment, 'development' for local
NODE_ENV=development
PORT=3001

# ─── Database Configuration (Supabase) ────────────────────────
# Pooled connection string (port 6543) for app scale
DATABASE_URL="postgresql://postgres.[REF]:[PASS]@[HOST]:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection string (port 5432) for migrations
DIRECT_URL="postgresql://postgres.[REF]:[PASS]@[HOST]:5432/postgres?sslmode=require"

# ─── Security Configuration ───────────────────────────────────
# Min 32 characters for production
JWT_SECRET=finance_dashboard_super_secret_jwt_key_32_chars_long
JWT_EXPIRES_IN=7d

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ─────────────────────────────────────────────────
# trace, debug, info, warn, error, fatal
LOG_LEVEL=info
